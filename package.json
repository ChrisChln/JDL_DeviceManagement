{
  "name": "jdl-device-management",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "bash ./scripts/run-dev.sh",
    "dev:host": "bash ./scripts/run-dev.sh --host",
    "dev:frontend": "npm run dev -w frontend",
    "dev:frontend:host": "npm run dev -w frontend -- --host",
    "dev:backend": "npm run dev -w backend",
    "build": "npm run build -w frontend",
    "start": "npm run start -w backend",
    "install:deps": "npm install",
    "check:conflicts": "node scripts/mergeConflictCheck.js",
    "test:conflicts": "node --test scripts/mergeConflictCheck.test.js"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
